// EcoWise AI — Prisma Schema
// Carbon Footprint Awareness Platform

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum ProfileType {
  STUDENT
  PROFESSIONAL
  FAMILY
  ENTHUSIAST
  GENERAL
}

enum Category {
  TRANSPORT
  FOOD
  ENERGY
  SHOPPING
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum Impact {
  LOW
  MEDIUM
  HIGH
}

enum ChallengeType {
  DAILY
  WEEKLY
  MONTHLY
}

enum ChallengeStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

// ──────────────────────────────────────────────
// User Model
// ──────────────────────────────────────────────
model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  passwordHash  String
  role          Role         @default(USER)
  profileType   ProfileType  @default(GENERAL)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  activities      Activity[]
  recommendations Recommendation[]
  challenges      Challenge[]
  auditLogs       AuditLog[]

  @@index([email])
  @@index([role])
}

// ──────────────────────────────────────────────
// Activity Model — Carbon-emitting activities
// ──────────────────────────────────────────────
model Activity {
  id          String   @id @default(cuid())
  userId      String
  category    Category
  subCategory String   // car, bus, train, bike, flight, vegetarian, mixed, high_meat, electricity, water, clothing, electronics
  value       Float    // distance in km, days, kWh, m³, or item count
  unit        String   // km, days, kWh, m3, items
  co2Amount   Float    // calculated kg CO₂e
  date        DateTime
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@index([date])
}

// ──────────────────────────────────────────────
// Recommendation Model — AI-generated suggestions
// ──────────────────────────────────────────────
model Recommendation {
  id                String    @id @default(cuid())
  userId            String
  category          Category
  title             String
  description       String
  reasoning         String
  difficulty        Difficulty
  impact            Impact
  estimatedReduction Float    // Estimated kg CO₂e reduction per month
  confidenceScore   Float     @default(80) // AI confidence score
  accepted          Boolean   @default(false)
  completedAt       DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, category])
  @@index([userId, accepted])
}

// ──────────────────────────────────────────────
// Challenge Model — Sustainability challenges
// ──────────────────────────────────────────────
model Challenge {
  id              String    @id @default(cuid())
  userId          String
  type            ChallengeType
  title           String
  description     String
  category        Category
  targetReduction Float
  status          ChallengeStatus @default(ACTIVE)
  startDate       DateTime
  endDate         DateTime
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@index([userId, type])
}

// ──────────────────────────────────────────────
// AuditLog Model — Security & activity auditing
// ──────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String   // LOGIN | LOGOUT | REGISTER | PASSWORD_RESET | ACTIVITY_CREATE | ADMIN_ACTION | SECURITY_FAILURE
  details   String?
  ipAddress String?
  userAgent String?
  timestamp DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([timestamp])
}
